# ── Required ──────────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=your-telegram-bot-token-here
DISCORD_TOKEN=your-discord-bot-token-here

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Storage ───────────────────────────────────────────────────────────────────
DATA_FILE=/app/data/config.json

# ══════════════════════════════════════════════════════════════════════════════
# Translation providers  (all optional — enable what you have)
# Each pair can choose its provider independently in the dashboard.
# ══════════════════════════════════════════════════════════════════════════════

# ── AI Models ─────────────────────────────────────────────────────────────────

# Anthropic (Claude Haiku)
# Get key: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI (GPT-4o-mini)
# Get key: https://platform.openai.com/
OPENAI_API_KEY=

# Ollama — local LLM, no API key needed
# Install: https://ollama.com/  →  ollama pull llama3
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Dedicated Translation APIs ────────────────────────────────────────────────

# Google Cloud Translation (v2 / Basic API)
# Get key: https://console.cloud.google.com/ → Enable "Cloud Translation API"
GOOGLE_TRANSLATE_API_KEY=

# DeepL  (free tier available, key ends with :fx)
# Get key: https://www.deepl.com/pro-api
DEEPL_API_KEY=

# LibreTranslate — open-source, self-hostable, no key needed by default
# Docker: docker run -p 5000:5000 libretranslate/libretranslate
# Or use a public instance (may require an API key)
LIBRETRANSLATE_URL=http://localhost:5000
LIBRETRANSLATE_API_KEY=

# Microsoft Translator (Azure Cognitive Services)
# Get key: https://portal.azure.com/ → Translator resource
MICROSOFT_TRANSLATOR_KEY=
MICROSOFT_TRANSLATOR_REGION=global
